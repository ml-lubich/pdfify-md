{
  "all": false,
  "check-coverage": true,
  "extension": [
    ".ts",
    ".tsx"
  ],
  "lines": 80,
  "functions": 80,
  "branches": 80,
  "statements": 80,
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "src/test/**",
    "dist/**",
    "node_modules/**",
    "**/*.d.ts"
  ],
  "reporter": [
    "text",
    "text-summary",
    "html",
    "lcov"
  ],
  "report-dir": "coverage"
}
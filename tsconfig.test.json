{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"noEmit": true,
		"rootDir": ".",
		"outDir": null,
		"noUnusedLocals": false,
		"noUnusedParameters": false
	},
	"include": ["src"],
	"ts-node": {
		"transpileOnly": true,
		"experimentalResolver": true,
		"files": true,
		"compilerOptions": {
			"module": "commonjs"
		}
	}
}
